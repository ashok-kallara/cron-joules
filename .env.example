# Vehicle Provider — set to "kia" or "tesla"
VEHICLE_PROVIDER=kia
# Display name used in Telegram messages (defaults to "EV6" for kia, "Tesla" for tesla)
# VEHICLE_NAME=EV6

# Kia Connect Credentials (required when VEHICLE_PROVIDER=kia)
KIA_USERNAME=your_email@example.com
KIA_PASSWORD=your_password
KIA_PIN=1234

# Tesla Credentials (required when VEHICLE_PROVIDER=tesla)
# Run scripts/tesla_auth.py once to get the refresh token
TESLA_EMAIL=your_tesla_email@example.com
TESLA_REFRESH_TOKEN=your_refresh_token
# TESLA_VIN=XXXXXXXXXXXXXXXXX  # Optional: target a specific vehicle

# Telegram Bot Configuration
# Create a bot via @BotFather and get the token
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# Chat ID of your group or personal chat (use @userinfobot to find it)
TELEGRAM_CHAT_ID=-1001234567890

# Upstash Redis (https://console.upstash.com)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Logging
LOG_LEVEL=DEBUG
