# Kia Connect Credentials
KIA_USERNAME=your_email@example.com
KIA_PASSWORD=your_password
KIA_PIN=1234

# Telegram Bot Configuration
# Create a bot via @BotFather and get the token
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# Chat ID of your group or personal chat (use @userinfobot to find it)
TELEGRAM_CHAT_ID=-1001234567890
# Secret token for verifying Telegram webhook requests (set when registering webhook)
TELEGRAM_WEBHOOK_SECRET=your-random-secret-string

# Assistant / IFTTT Webhook Configuration
# Secret for authenticating IFTTT requests (send as X-Webhook-Secret header)
ASSISTANT_WEBHOOK_SECRET=your-assistant-webhook-secret

# AWS Configuration (for local testing)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
DYNAMODB_TABLE=cron-joules-dev

# Logging
LOG_LEVEL=DEBUG
